{
  "name": "service-ticket-system",
  "version": "1.0.0",
  "description": "",
  "main": "server.ts",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "nodemon --watch src --ext ts --exec ts-node src/server.ts",
    "postinstall": "npm run build",
    "db:sync": "ts-node src/scripts/sync-db.ts",
    "seed:roles": "ts-node src/scripts/seed-roles.ts",
    "seed:status": "ts-node src/scripts/seed-ticket-status.ts",
    "seed:users": "ts-node src/scripts/seed-users.ts",
    "seed:all": "npm run seed:roles && npm run seed:status && npm run seed:users",
    "db:reset": "npm run db:sync && npm run seed:all"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.12.12",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^7.0.11",
    "@types/uuid": "^10.0.0",
    "nodemon": "^3.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.20.0",
    "node-cron": "^3.0.3",
    "sequelize": "^6.37.3",
    "yup": "^1.7.1"
  },
  "overrides": {
    "minimatch": "^10.2.1"
  }
}
